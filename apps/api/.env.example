PORT=3051
BASE_URL=http://localhost:3000

# Required in production — used to sign access tokens (change the dev default).
JWT_SECRET=change-me-to-a-long-random-string

# Open registration on POST /api/auth/register: allowed by default in non-production.
# In production, registration is disabled unless set to true.
# ALLOW_OPEN_REGISTRATION=true

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=drug_store
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Platform bootstrap seed (runs on API startup; `pnpm run seed` is optional).
# Idempotent: reuses existing tenant/user by name/email and ensures membership exists.
PLATFORM_TENANT_NAME=Platform
PLATFORM_OWNER_EMAIL=platform.owner@pharma.local
# Provide ONE of the following (required in production when the owner user does not exist yet).
# In non-production, omit both to use a logged dev-only default password instead.
PLATFORM_OWNER_PASSWORD=replace-with-long-random-password
# PLATFORM_OWNER_PASSWORD_HASH=$2b$10$replace.with.bcrypt.hash
